# ChecaAI Web — Environment Variables
# Copy this file to .env.local and fill in the values

# URL of the .NET backend API (no trailing slash)
NEXT_PUBLIC_API_URL=https://localhost:7001

# Internal URL for server-side API calls (API routes) — can differ from public URL
API_URL=https://localhost:7001

# Anthropic Claude API Key — required for AI features (/busca, politician analysis, session explanation)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
